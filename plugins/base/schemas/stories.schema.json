{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "stories.schema.json",
  "title": "Epic Stories Schema",
  "description": "Authoritative schema for stories.json - story definitions within an epic",
  "type": "object",
  "required": ["epic_name", "created_at", "total_stories", "stories", "story_order"],
  "properties": {
    "epic_name": {
      "type": "string",
      "description": "Name of the epic (kebab-case)"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when stories were created"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last update"
    },
    "total_stories": {
      "type": "integer",
      "minimum": 1,
      "description": "Total number of stories in the epic"
    },
    "stories": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/story"
      },
      "minItems": 1
    },
    "story_order": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[0-9]{2}$"
      },
      "description": "Ordered list of story IDs for implementation sequence"
    },
    "dependency_notes": {
      "type": "string",
      "description": "Explanation of story dependencies and independence strategy"
    },
    "mock_resolution_plan": {
      "type": "string",
      "description": "Plan for resolving any temporary mocks introduced"
    },
    "seams": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["data", "source", "destination", "contract"],
        "properties": {
          "data": { "type": "string" },
          "contract": { "$ref": "#/$defs/seam_contract" },
          "source": { "$ref": "#/$defs/seam_endpoint" },
          "intermediaries": {
            "type": "array",
            "items": { "$ref": "#/$defs/seam_endpoint" }
          },
          "destination": { "$ref": "#/$defs/seam_endpoint" }
        }
      },
      "default": [],
      "description": "Cross-story data flow seams — each seam requires a typed contract frozen before parallel implementation"
    }
  },
  "$defs": {
    "story": {
      "type": "object",
      "required": ["id", "name", "title", "description", "acceptance_criteria", "complexity", "status"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[0-9]{2}$",
          "description": "Two-digit story identifier (01, 02, ...)"
        },
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "description": "Kebab-case slug for the story"
        },
        "title": {
          "type": "string",
          "description": "Human-readable story title"
        },
        "description": {
          "type": "string",
          "description": "What the story delivers"
        },
        "acceptance_criteria": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^AC-[A-Z]+-[0-9]+$"
          },
          "minItems": 1,
          "description": "List of acceptance criteria IDs this story covers (form: AC-<TAG>-<N>, e.g. AC-STRUCT-7, AC-DEP-3 — see base:spec-template)"
        },
        "scope": {
          "type": "object",
          "properties": {
            "includes": {
              "type": "array",
              "items": { "type": "string" },
              "description": "What is in scope for this story"
            },
            "excludes": {
              "type": "array",
              "items": { "type": "string" },
              "description": "What is explicitly out of scope"
            }
          },
          "description": "Scope boundaries for the story"
        },
        "complexity": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "description": "Implementation complexity estimate"
        },
        "mock_dependencies": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Temporary mocks this story depends on (must be resolved by other stories)"
        },
        "introduces_mocks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/temporary_mock"
          },
          "default": [],
          "description": "Temporary mocks this story introduces (MUST be resolved before epic completion)"
        },
        "test_fixtures": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/test_fixture"
          },
          "description": "Permanent test fixtures/doubles (NOT tracked as mocks, stay forever)"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "in_progress", "done", "blocked", "escalated"],
          "description": "Current story status"
        },
        "owning_module": {
          "type": "string",
          "description": "Name of the module this story belongs to and is responsible for implementing (must match a module in architecture.md)"
        },
        "creates_seam": {
          "type": "boolean",
          "default": false,
          "description": "True if this story creates a new cross-story seam contract"
        },
        "lighter_path": {
          "type": "boolean",
          "default": false,
          "description": "When true, /base:feature Step 5 skips the integration-architect spawn for this story; lead implements directly via Edit. Examiner still runs. Emitted by base:story-planner Mode 2 only when all three conditions of AC-STORY-2 hold (markdown-class file targets, ACs fully specified, no new-file scaffolding). See specs/epic-fast-track-routing/spec.md ## Technical Approach and base:story-planner Mode 2 for the deterministic emission rule."
        },
        "consumes_seams": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "type_names of seam contracts this story depends on (must be defined in the top-level seams array)"
        },
        "notes": {
          "type": "string",
          "description": "Additional context or implementation notes"
        }
      }
    },
    "temporary_mock": {
      "type": "object",
      "required": ["mock_id", "description", "interface_mocked"],
      "properties": {
        "mock_id": {
          "type": "string",
          "pattern": "^MOCK-[0-9]{2}-[0-9]{3}$",
          "description": "Unique mock identifier (MOCK-{story_id}-{sequence})"
        },
        "description": {
          "type": "string",
          "description": "What is being mocked and why"
        },
        "interface_mocked": {
          "type": "string",
          "description": "The interface or component being mocked"
        },
        "resolution_story": {
          "type": ["string", "null"],
          "description": "Story ID that will resolve this mock"
        }
      }
    },
    "seam_contract": {
      "type": "object",
      "required": ["type_name"],
      "description": "Typed interface contract that stories agree on before implementation",
      "properties": {
        "type_name": {
          "type": "string",
          "description": "Name of the interface or type (e.g. PaymentResult, UserEvent)"
        },
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "type"],
            "properties": {
              "name": { "type": "string" },
              "type": { "type": "string" },
              "optional": { "type": "boolean", "default": false }
            }
          }
        },
        "invariants": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Testable assertions this contract must satisfy (e.g. 'amount is always positive')"
        }
      }
    },
    "seam_endpoint": {
      "type": "object",
      "required": ["story", "artifact"],
      "properties": {
        "story": { "type": "string" },
        "artifact": { "type": "string" }
      }
    },
    "test_fixture": {
      "type": "object",
      "required": ["fixture_id", "description", "interface", "reason", "permanent"],
      "properties": {
        "fixture_id": {
          "type": "string",
          "pattern": "^FIXTURE-[0-9]{2}-[0-9]{3}$",
          "description": "Unique fixture identifier"
        },
        "description": {
          "type": "string",
          "description": "What the fixture provides"
        },
        "interface": {
          "type": "string",
          "description": "The interface this fixture implements"
        },
        "reason": {
          "type": "string",
          "description": "Why this is a permanent fixture (e.g., external service)"
        },
        "permanent": {
          "type": "boolean",
          "const": true,
          "description": "Always true for fixtures (distinguishes from temporary mocks)"
        }
      }
    }
  }
}
